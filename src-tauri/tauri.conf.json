{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "IMU FFT",
  "version": "0.1.2",
  "identifier": "com.koetob.imu-fft",
  "build": {
    "beforeDevCommand": "npm run dev:frontend",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build:frontend",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "IMU FFT",
        "width": 1200,
        "height": 780,
        "minWidth": 880,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "msi"
    ],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQxQkI5RDM1NDcxNzE3QTYKUldTbUZ4ZEhOWjI3UWJtSm9WQmg5RU5mRnFmNk13cmFVdmN1bSt6U3djUWh4THNDdUplMkROKzMK",
      "endpoints": [
        "https://github.com/TobiasKoehlerETH/imu-fft/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
