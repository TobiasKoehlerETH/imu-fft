{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "IMU FFT",
  "version": "0.1.0",
  "identifier": "com.koetob.imu-fft",
  "build": {
    "beforeDevCommand": "npm run dev:frontend",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build:frontend",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "IMU FFT",
        "width": 1200,
        "height": 780,
        "minWidth": 880,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "icon": ["icons/icon.ico"]
  }
}
